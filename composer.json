{
    "name": "cjmellor/approval",
    "description": "Approve or Deny new Model data before it is persisted",
    "keywords": [
        "cjmellor",
        "laravel",
        "approval"
    ],
    "homepage": "https://github.com/cjmellor/approval",
    "license": "MIT",
    "authors": [
        {
            "name": "Chris Mellor",
            "email": "cmellor@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/contracts": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "driftingly/rector-laravel": "^2.0",
        "laravel/boost": "^1.1",
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^10.1|^11.0",
        "pestphp/pest": "^3.7|^4.4",
        "pestphp/pest-plugin-arch": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.1|^4.1",
        "pestphp/pest-plugin-type-coverage": "^3.3|^4.0",
        "rector/rector": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Cjmellor\\Approval\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Cjmellor\\Approval\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@clear",
            "@prepare",
            "@php ./vendor/bin/testbench package:discover --ansi"
        ],
        "build": "@php vendor/bin/testbench workbench:build --ansi",
        "clear": "@php vendor/bin/testbench package:purge-skeleton --ansi",
        "lint": "@php vendor/bin/pint --ansi",
        "lint:dirty": "@php vendor/bin/pint --dirty --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "refactor": "rector",
        "refactor:dry-run": "rector process --dry-run",
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "@build",
            "@php vendor/bin/testbench serve --ansi"
        ],
        "test": "vendor/bin/pest",
        "test:types": "vendor/bin/pest --type-coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Cjmellor\\Approval\\ApprovalServiceProvider"
            ],
            "aliases": {}
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
